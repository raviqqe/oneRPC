{
  "name": "onerpc",
  "version": "0.6.11",
  "description": "The RPC library for the serverless and TypeScript era.",
  "license": "MIT",
  "repository": "https://github.com/raviqqe/onerpc",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "default": "./dist/validation.js"
    },
    "./adapter/*": {
      "types": "./dist/adapter/*.d.ts",
      "default": "./dist/adapter/*.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "build:tsc": "tsc --emitDeclarationOnly",
    "build:doc": "deno doc --unstable-sloppy-imports --unstable-byonm --html --name='⚡ oneRPC' src/index.ts src/client.ts src/middleware.ts src/validation.ts src/adapter/*.ts",
    "lint": "biome ci",
    "test": "vitest --coverage"
  },
  "dependencies": {
    "@raviqqe/hidash": "^2.0.3",
    "@raviqqe/loscore": "^0.3.0",
    "es-toolkit": "^1.39.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@raviqqe/biome-config": "^2.0.16",
    "@raviqqe/tsconfig": "^3.0.0",
    "@rslib/core": "^0.20.0",
    "@types/aws-lambda": "^8.10.152",
    "@vitest/coverage-v8": "^4.0.1",
    "esbuild": "^0.27.3",
    "typescript": "^6.0.2",
    "valibot": "^1.3.1",
    "vitest": "^4.0.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "valibot": "^1.3.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=25.8.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
